<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="SUPPORTHUB_DATABASE_URL" value="postgresql+psycopg://supporthub_user:259487123@127.0.0.1:5432/supporthub" />
  </appSettings>

  <system.webServer>
    <rewrite>
      <!-- Outbound: rewrite Location from http://127.0.0.1:8888/... to https://{HTTP_HOST}/... -->
      <outboundRules>
        <preConditions>
          <preCondition name="IsRedirect">
            <add input="{RESPONSE_STATUS}" pattern="3\d\d" />
          </preCondition>
        </preConditions>
      </outboundRules>
      <rules>
        <rule name="ReverseProxyInboundRule1" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8888/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Enable ARR proxy and in IIS > Server Proxy Settings enable:
         - Enable proxy
         - Reverse rewrite host in response headers -->

    <!-- Pass through app errors and do not replace with IIS default error page -->
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
